ENVIRONMENT=development
SERVICE_NAME=neo4j-semantic-query-service
SERVICE_VERSION=1.0.0
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-a-strong-password
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT_SECONDS=10
NEO4J_CONNECTION_ACQUISITION_TIMEOUT_SECONDS=30
NEO4J_MAX_TRANSACTION_RETRY_SECONDS=30

BOOTSTRAP_SCHEMA_ON_STARTUP=true
FAIL_STARTUP_WHEN_NEO4J_UNAVAILABLE=true
API_KEY=replace-reader-key
ADMIN_API_KEY=replace-admin-key
CORS_ORIGINS_CSV=http://localhost:3000,http://localhost:5173

INGESTION_BATCH_SIZE=250
MAX_INGESTION_PROFILES=100000
MAX_INGESTION_BODY_BYTES=104857600
MAXIMUM_QUERY_LIMIT=500
MAXIMUM_DEPENDENCY_DEPTH=8
CATALOG_CACHE_SECONDS=60
STORE_RAW_PROFILE=false
